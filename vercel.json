{
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php@0.7.3"
        },
        {
            "src": "public/(.*)",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ],
    "env": {
        "PHP_VERSION": "8.2"
    }
}
